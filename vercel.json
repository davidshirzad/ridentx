{
  "version": 2,
  "functions": {
    "bikereg.js": { "runtime": "edge" },
    "bikesignup.js": { "runtime": "edge" }
  },
  "routes": [
    { "src": "/api/bikereg", "dest": "/bikereg.js" },
    { "src": "/api/bikesignup", "dest": "/bikesignup.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
